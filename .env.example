# New API 环境变量示例
# 
# 复制此文件为 .env 并修改配置
# cp .env.example .env
#
# 注意：不要提交 .env 到 git！

# ========================================
# 基础配置
# ========================================

# 服务端口（WSL 开发环境使用 13001，避免与 Windows 3001 冲突）
PORT=13001

# 前端基础 URL（可选）
# FRONTEND_BASE_URL=https://your-frontend-url.com

# ========================================
# 数据库配置
# ========================================

# 数据库连接字符串
# 
# SQLite (开发环境推荐):
# SQL_DSN=
# SQLITE_PATH=./data/new-api.db
#
# PostgreSQL:
# SQL_DSN=postgresql://user:password@localhost:5432/newapi
#
# MySQL:
# SQL_DSN=user:password@tcp(localhost:3306)/newapi?parseTime=true

SQL_DSN=

# SQLite 数据库路径（使用 SQLite 时设置）
SQLITE_PATH=./data/new-api.db

# 日志数据库连接（可选）
# LOG_SQL_DSN=user:password@tcp(localhost:3306)/logdb

# 数据库连接池配置
SQL_MAX_IDLE_CONNS=20
SQL_MAX_OPEN_CONNS=100
SQL_CONN_MAX_LIFETIME=60

# ========================================
# 缓存配置
# ========================================

# Redis 连接字符串（可选，但推荐）
# REDIS_CONN_STRING=redis://:password@localhost:6379/0

# 同步频率（秒）
SYNC_FREQUENCY=120

# 启用内存缓存
MEMORY_CACHE_ENABLED=true

# 批量更新配置
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=300

# ========================================
# 日志配置
# ========================================

# 日志目录
LOG_DIR=./logs

# 启用错误日志
ERROR_LOG_ENABLED=true

# ========================================
# 性能配置
# ========================================

# Gin 框架模式 (debug / release)
GIN_MODE=release

# 全局 API 速率限制 (0 = 无限制)
GlobalApiRateLimit=0

# ========================================
# 代理配置（可选）
# ========================================

# HTTP 代理
# HTTP_PROXY=http://127.0.0.1:7897

# HTTPS 代理
# HTTPS_PROXY=http://127.0.0.1:7897

# ========================================
# 安全配置
# ========================================

# 会话密钥（多节点部署必须设置）
# 生成随机字符串: openssl rand -hex 32
# SESSION_SECRET=change-me-to-random-string

# TLS 配置
TLS_INSECURE_SKIP_VERIFY=false

# ========================================
# 调试配置（生产环境勿启用）
# ========================================

# 启用调试模式
# DEBUG=false

# 启用 pprof
# ENABLE_PPROF=false

# ========================================
# 功能配置
# ========================================

# 启用更新任务
UPDATE_TASK=true

# 生成默认 token
GENERATE_DEFAULT_TOKEN=false

# 统计图片 token
GET_MEDIA_TOKEN=true
GET_MEDIA_TOKEN_NOT_STREAM=false

# ========================================
# 超时配置
# ========================================

# 请求超时（秒，0 = 不限制）
RELAY_TIMEOUT=0

# 空闲连接超时（秒）
RELAY_IDLE_CONN_TIMEOUT=90

# 流模式超时（秒）
STREAMING_TIMEOUT=300

# ========================================
# 节点配置（多节点部署时设置）
# ========================================

# 节点名称
NODE_NAME=new-api-dev

# 节点类型 (master / slave)
# NODE_TYPE=master

# ========================================
# 分析配置（可选）
# ========================================

# Google Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Umami Analytics
# UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# ========================================
# 第三方登录（可选）
# ========================================

# LinuxDo
# LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
# LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

# ========================================
# 其他配置
# ========================================

# Cohere 安全设置
# COHERE_SAFETY_SETTING=NONE

# Dify 调试
# DIFY_DEBUG=false

# Gemini 视觉最大图片数量
# GEMINI_VISION_MAX_IMAGE_NUM=16

# 可信任重定向域名（逗号分隔）
# TRUSTED_REDIRECT_DOMAINS=example.com,myapp.io

